# Nemetron proxy configuration
NEMETRON_BASE_URL=http://localhost:11434
NEMETRON_API_KEY=not-needed
NEMETRON_MODEL=nemetron-30b
PROXY_HOST=0.0.0.0
PROXY_PORT=8000

# Output token handling
DEFAULT_MAX_TOKENS=8192
MAX_OUTPUT_TOKENS=32768

# Tool filtering: comma-separated list of tool names to expose to the model
# Available: read_file, read_multiple_files, write_file, edit_file, list_directory,
#            search_codebase, run_commands, create_folder, fetch_web_content, ask_question
ALLOWED_TOOLS=read_file,read_multiple_files,write_file,edit_file,list_directory,search_codebase,run_commands,create_folder,fetch_web_content

# Logging
LOG_LEVEL=INFO
